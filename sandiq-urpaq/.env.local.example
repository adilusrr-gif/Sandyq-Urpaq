# Supabase — берёте из dashboard.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Secret — только на сервере (никогда не NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — для транскрипции и генерации сертификатов
OPENAI_API_KEY=sk-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Kaspi Pay
# Для тестового Vercel-запуска можно оставить пустыми:
# тогда приложение включит демо-активацию вместо реального редиректа на Kaspi.
KASPI_MERCHANT_ID=
KASPI_SECRET=
